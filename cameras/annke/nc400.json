{
  "id": "annke-nc400",
  "brand": "Annke",
  "model": "NC400",
  "type": "dome",
  "connectivity": [
    "ethernet"
  ],
  "release_year": 2023,
  "resolution": {
    "megapixels": 4,
    "label": "4MP"
  },
  "field_of_view_deg": "107h",
  "night_vision": {
    "type": "ir",
    "range_m": 30
  },
  "power": {
    "method": "PoE / DC 12V"
  },
  "storage": {
    "onboard": true,
    "max_microsd_gb": 256,
    "nvr_compatible": true,
    "cloud": false
  },
  "protocols": [
    "onvif",
    "rtsp"
  ],
  "ip_rating": "IP67",
  "audio": {
    "microphone": false,
    "speaker": false,
    "two_way": false
  },
  "features": [
    "Annke NC400 4MP PoE dome AI",
    "human/vehicle detection",
    "30m IR",
    "H.265+",
    "IP67",
    "IK10",
    "ONVIF/RTSP"
  ],
  "sources": [
    "https://www.annke.com/"
  ],
  "power_source": [
    "poe",
    "dc"
  ],
  "configs": {
    "frigate": {
      "detect": {
        "width": 1280,
        "height": 720,
        "fps": 5
      },
      "rtsp_url_template": "rtsp://{user}:{pass}@{ip}:554/Streaming/Channels/101",
      "best_substream": "rtsp://{user}:{pass}@{ip}:554/Streaming/Channels/102"
    },
    "home_assistant": {
      "integration": "onvif",
      "notes": "Uses Hikvision protocol. ONVIF integration works."
    },
    "blue_iris": {
      "profile": "Hikvision",
      "notes": "Select 'Hikvision' profile. Most Annke cameras use Hikvision protocol."
    }
  }
}
