    "microphone": true,
    "speaker": false,
    "two_way": false
  },
  "features": [
    "4K PoE dome camera",
    "ONVIF compatible",
    "True Detect PIR heat sensing",
    "smart motion detection",
    "H.265",
    "IP66 weatherproof"
  ],
  "sources": [
    "https://www.swann.com/"
  ],
  "power_source": [
    "poe"
