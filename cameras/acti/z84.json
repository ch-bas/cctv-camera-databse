    "max_width": 1920,
    "max_height": 1080,
    "label": "1080p FHD"
  },
  "sensor": "1/2.8\" CMOS",
  "lens": {
    "count": 1,
    "focal_length_mm": "2.8",
    "varifocal": false
  },
  "field_of_view_deg": "110 horizontal",
  "night_vision": {
    "type": "ir",
    "range_m": 15
  },
  "power": {
    "method": "PoE (IEEE 802.3af) / DC 12V"
  },
  "storage": {
    "onboard": true,
    "nvr_compatible": true,
    "cloud": false
  },
  "protocols": [
    "rtsp",
    "onvif"
  ],
  "audio": {
    "microphone": true,
    "speaker": true,
    "two_way": true
  },
  "features": [
    "2MP indoor mini dome",
    "adaptive IR 15m",
    "WDR",
    "H.265/H.264",
    "ONVIF Profile S/T/G",
    "two-way audio",
    "compact design"
  ],
  "sources": [
    "https://www.acti.com/product/Z84"
  ],
  "power_source": [
    "poe",
    "dc"
  ],
  "configs": {
    "frigate": {
      "detect": {
        "width": 640,
        "height": 480,
        "fps": 5
      },
      "rtsp_url_template": "rtsp://{user}:{pass}@{ip}:7070/stream1"
    },
    "home_assistant": {
      "integration": "onvif",
      "notes": "Use ONVIF integration. RTSP port is 7070 by default."
    },
    "blue_iris": {
      "profile": "ACTi",
      "notes": "Select 'ACTi' profile. Default RTSP port is 7070."
    }
  }
