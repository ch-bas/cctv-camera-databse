    "microphone": true,
    "speaker": true,
    "two_way": true
  },
  "features": [
    "2K QHD indoor/outdoor",
    "starlight color night vision",
    "AI person/pet/vehicle detection",
    "activity zones",
    "built-in siren",
    "IP44 all-weather use",
    "RTSP/ONVIF",
    "Alexa / Google",
    "no subscription"
