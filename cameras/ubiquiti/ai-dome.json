{
  "id": "ubiquiti-ai-dome",
  "brand": "Ubiquiti",
  "model": "UniFi Protect AI Dome",
  "aliases": [
    "UVC-AI-Dome"
  ],
  "type": "dome",
  "connectivity": [
    "ethernet"
  ],
  "resolution": {
    "megapixels": 8,
    "max_width": 3840,
    "max_height": 2160,
    "label": "4K UHD"
  },
  "sensor": "1/1.8\" CMOS",
  "lens": {
    "count": 1,
    "focal_length_mm": "2.8 (fixed)",
    "aperture": "F1.6",
    "varifocal": false
  },
  "field_of_view_deg": "96 horizontal",
  "night_vision": {
    "type": "ir",
    "range_m": 30
  },
  "power": {
    "method": "PoE (802.3at)"
  },
  "storage": {
    "onboard": false,
    "nvr_compatible": true,
    "cloud": false
  },
  "protocols": [
    "rtsp"
  ],
  "ip_rating": "IP66",
  "audio": {
    "microphone": true,
    "speaker": false,
    "two_way": false
  },
  "features": [
    "4K AI camera",
    "enhanced AI face/LPR detection",
    "UniFi Protect ecosystem",
    "IK09",
    "long-range IR",
    "built-in mic"
  ],
  "release_year": 2024,
  "sources": [
    "https://store.ui.com/us/en/products/uvc-ai-dome"
  ],
  "power_source": [
    "poe"
  ],
  "configs": {
    "frigate": {
      "detect": {
        "width": 1280,
        "height": 720,
        "fps": 5
      },
      "rtsp_url_template": "rtsps://{ip}:7441/{camera_id}?enableSrtp"
    },
    "home_assistant": {
      "integration": "unifiprotect",
      "notes": "Native UniFi Protect integration. Requires UniFi Protect console."
    },
    "blue_iris": {
      "profile": "Generic/RTSP",
      "notes": "Use Generic/RTSP profile with RTSPS URL from UniFi Protect. Requires Protect RTSP stream enabled per camera."
    }
  }
}
