  "sensor": "1/1.8\" CMOS",
  "lens": {
    "count": 1,
    "focal_length_mm": "2.8-12",
    "aperture": "F1.6",
    "varifocal": true
  },
  "field_of_view_deg": "108-38 horizontal",
  "night_vision": {
    "type": "ir",
    "range_m": 30
  },
  "power": {
    "method": "PoE (802.3at)"
  },
  "storage": {
    "onboard": false,
    "nvr_compatible": true,
    "cloud": false
  },
  "protocols": [
    "rtsp"
  ],
  "ip_rating": "IP66",
  "audio": {
    "microphone": true,
    "speaker": false,
    "two_way": false
  },
  "features": [
    "4K UHD",
    "4x optical zoom",
    "1/1.8\" large sensor",
    "AI event detection person/vehicle",
    "UniFi Protect ecosystem",
    "built-in mic"
  ],
  "release_year": 2024,
  "sources": [
    "https://techspecs.ui.com/unifi/cameras-nvrs/uvc-g5-pro"
  ],
  "power_source": [
    "poe"
  ],
  "configs": {
    "frigate": {
      "detect": {
        "width": 1280,
        "height": 720,
        "fps": 5
      },
      "rtsp_url_template": "rtsps://{ip}:7441/{camera_id}?enableSrtp"
    },
    "home_assistant": {
      "integration": "unifiprotect",
      "notes": "Native UniFi Protect integration. Requires UniFi Protect console."
    },
    "blue_iris": {
      "profile": "Generic/RTSP",
      "notes": "Use Generic/RTSP profile with RTSPS URL from UniFi Protect. Requires Protect RTSP stream enabled per camera."
    }
  }
