  ],
  "audio": {
    "microphone": true,
    "speaker": true,
    "two_way": true
  },
  "features": [
    "video doorbell",
    "built-in display",
    "WiFi 6",
    "person detection",
    "package detection",
    "two-way audio",
    "UniFi Protect ecosystem"
  ],
  "release_year": 2022,
  "msrp_usd": 199,
  "sources": [
