{
  "id": "camius-triton",
  "brand": "Camius",
  "model": "Triton",
  "type": "turret",
  "connectivity": [
    "ethernet"
  ],
  "resolution": {
    "megapixels": 5,
    "max_width": 2592,
    "max_height": 1944,
    "label": "5MP Super HD"
  },
  "sensor": "1/2.7\" CMOS",
  "night_vision": {
    "type": "ir",
    "range_m": 30
  },
  "power": {
    "method": "PoE (IEEE 802.3af) / DC 12V"
  },
  "storage": {
    "onboard": false,
    "nvr_compatible": true,
    "cloud": false
  },
  "protocols": [
    "onvif",
    "rtsp"
  ],
  "ip_rating": "IP67",
  "audio": {
    "microphone": true,
    "speaker": true,
    "two_way": true
  },
  "features": [
    "no subscription required",
    "two-way audio",
    "motion detection",
    "WDR"
  ],
  "release_year": 2023,
  "sources": [
    "https://camius.com/"
  ],
  "power_source": [
    "poe",
    "dc"
  ],
  "configs": {
    "frigate": {
      "detect": {
        "width": 1280,
        "height": 720,
        "fps": 5
      },
      "rtsp_url_template": "rtsp://{user}:{pass}@{ip}:554/cam/realmonitor?channel=1&subtype=0"
    },
    "home_assistant": {
      "integration": "onvif",
      "notes": "Use ONVIF integration."
    },
    "blue_iris": {
      "profile": "Generic/ONVIF",
      "notes": "Use Generic/ONVIF profile."
    }
  }
}
